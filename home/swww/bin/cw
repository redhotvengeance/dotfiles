#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/wallpapers/"
CURRENT_WALL=$(swww query | grep -o "/.*" | head -n 1)

# Get a random wallpaper that is not the current one
WALLPAPER=$(find "$WALLPAPER_DIR" -mindepth 1 -maxdepth 1 -type f -name "*.jpeg" ! -name "$(basename "$CURRENT_WALL")" | shuf -n 1)

# Apply the selected wallpaper
swww img "$WALLPAPER" --transition-type fade --transition-fps 120 --transition-duration 5

# Downsize for sampling
magick "$WALLPAPER" -resize 400x400\> /tmp/matugen_sample.jpg

# Make color palette from sampled wallpaper
if matugen image /tmp/matugen_sample.jpg --type scheme-fidelity; then
  # Reload waybar styles
  cp ~/.dotfiles/home/waybar/style.css ~/.dotfiles/home/waybar/style.css.tmp
  mv ~/.dotfiles/home/waybar/style.css.tmp ~/.dotfiles/home/waybar/style.css

  # Reload ghostty styles
  killall -SIGUSR2 ghostty

  # Reload hyprland styles
  hyprctl reload
else
  echo "Matugen failed to parse the image. Keeping current colors."
  exit 1
fi
